# OpenAI
OPENAI_API_KEY=sk-proj_xxx
OPENAI_MODEL=gpt-5.5

# Meta Marketing API
META_ACCESS_TOKEN=EAAB...
META_APP_ID=123456789
META_APP_SECRET=app-secret-usado-para-appsecret_proof
META_API_VERSION=v24.0

# Opcionais: use somente se quiser uma conta padrão.
# Para multi-conta, deixe em branco/remova e selecione a conta pelo frontend/chat.
META_BUSINESS_ID=
META_AD_ACCOUNT_ID=

# Login do painel web
ADMIN_EMAIL=sguilherme@sz4marketing.com
ADMIN_PASSWORD_HASH=scrypt:COLE_SALT_AQUI:COLE_HASH_AQUI
SESSION_SECRET=gere-um-segredo-longo
AUTH_COOKIE_SECURE=false

# Server
PORT=3000
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUDIT_LOG_PATH=./audit.log

# Fallback seguro:
# false = se a Meta recusar targeting_automation.individual_setting.geo, a alteração não é aplicada.
# true = permite aplicar somente geo_locations/location_types quando o campo de automação for recusado.
META_ALLOW_GEO_FALLBACK_WITHOUT_AUTOMATION=false
