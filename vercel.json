{
  "version": 2,
  "buildCommand": "npm run build",
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/(health|chat)$",
      "dest": "/api/index"
    },
    {
      "src": "^/(auth|config|meta)/(.*)$",
      "dest": "/api/index"
    },
    {
      "handle": "filesystem"
    }
  ]
}
