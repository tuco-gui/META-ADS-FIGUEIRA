{
  "name": "meta-ads-openai-assistant",
  "version": "1.0.0",
  "description": "Backend/API para operar Meta Ads com OpenAI Responses API, confirmação explícita e auditoria.",
  "type": "module",
  "main": "dist/index.cjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --external:openai --outfile=dist/index.cjs",
    "start": "node dist/index.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.1.0",
    "openai": "^6.37.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
